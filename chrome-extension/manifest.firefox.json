{
  "manifest_version": 2,
  "name": "Manga Translator Local Reader",
  "description": "Usa o backend do Manga Translator Local para OCR, tradução e leitura de mangás direto no navegador.",
  "version": "0.1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "manga-translator-local-reader@agevon.com",
      "strict_min_version": "109.0"
    }
  },
  "browser_action": {
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    },
    "default_title": "Manga Translator Local"
  },
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "background": {
    "scripts": ["extension-compat.js", "config.js", "background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["extension-compat.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["<all_urls>", "activeTab", "contextMenus", "storage", "tabs"]
}
